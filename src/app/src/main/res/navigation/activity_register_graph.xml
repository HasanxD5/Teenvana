<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/activity_register_graph"
    app:startDestination="@id/step1Fragment">

    <fragment
        android:id="@+id/step1Fragment"
        android:name="by.hasanxd5.teenvana.register.RegisterPhoneFragments$Step1Fragment"
        android:label="Step1Fragment">
        <action
            android:id="@+id/action_step1Fragment_to_step2Fragment"
            app:destination="@id/step2Fragment" />
    </fragment>

    <fragment
        android:id="@+id/step2Fragment"
        android:name="by.hasanxd5.teenvana.register.RegisterPhoneFragments$Step2Fragment"
        android:label="Step2Fragment" >
        <action
            android:id="@+id/action_step2Fragment_to_step3Fragment"
            app:destination="@id/step3Fragment" />
        <action
            android:id="@+id/action_step2Fragment_to_step1Fragment"
            app:destination="@id/step1Fragment" />
    </fragment>

    <fragment
        android:id="@+id/step3Fragment"
        android:name="by.hasanxd5.teenvana.register.RegisterUsersFragments$Step3Fragment"
        android:label="Step3Fragment">
        <action
            android:id="@+id/action_step3Fragment_to_step4Fragment"
            app:destination="@id/step4Fragment" />
        <action
            android:id="@+id/action_step3Fragment_to_step2Fragment"
            app:destination="@id/step2Fragment" />
    </fragment>

    <fragment
        android:id="@+id/step4Fragment"
        android:name="by.hasanxd5.teenvana.register.RegisterUsersFragments$Step4Fragment"
        android:label="Step4Fragment" />

</navigation>